# Copia este archivo a `.env.local` y rellena los valores reales.
# Nunca subas `.env.local` al repositorio.

# ── Supabase (obligatorio) ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Solo servidor — webhooks + panel /admin (Service Role, ignora RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Portero Digital ─────────────────────────────────────────────────────────
# Emails con acceso a /admin y bypass de la lista de suscriptores (coma-separados)
ADMIN_EMAILS=tu@correo.com

# ── Hotmart (monetización + registro automático en subscribers) ─────────────
HOTMART_HOTTOK=your-hotmart-hottok
NEXT_PUBLIC_HOTMART_CHECKOUT_URL=https://pay.hotmart.com/YOUR_PRODUCT_CHECKOUT

# ── Lemon Squeezy (Merchant of Record — path principal de pagos) ────────────
# Signing secret del webhook en Lemon Squeezy → Settings → Webhooks
# Endpoint: POST /api/webhooks/lemonsqueezy  (evento: order_created)
LEMONSQUEEZY_WEBHOOK_SECRET=your-lemonsqueezy-webhook-signing-secret

# ── Modo mantenimiento (telón / Coming Soon) ────────────────────────────────
# "true" = redirige todo el tráfico público a /maintenance
# Los webhooks (/api/webhooks/*) y estáticos NUNCA se bloquean.
MAINTENANCE_MODE=false

# ── Stripe (fallback opcional) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
