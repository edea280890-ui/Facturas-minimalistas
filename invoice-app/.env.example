# Copia este archivo a `.env.local` y rellena los valores reales.
# Nunca subas `.env.local` al repositorio.

# ── Supabase (obligatorio) ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Solo servidor — usado por webhooks Hotmart/Stripe para marcar is_premium
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Hotmart (monetización principal en la landing) ──────────────────────────
# Token secreto del webhook (panel Hotmart → Webhooks / hottok)
HOTMART_HOTTOK=your-hotmart-hottok
# Enlace público de checkout del producto Pro (aparece en CTAs de /)
NEXT_PUBLIC_HOTMART_CHECKOUT_URL=https://pay.hotmart.com/YOUR_PRODUCT_CHECKOUT

# ── Stripe (fallback de upgrade en /app si Hotmart no está configurado) ─────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
